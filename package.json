{
  "name": "the-vault-architect",
  "private": true,
  "version": "1.0.0",
  "description": "AI-native architecture workflow foundation",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @the-vault/shared && npm run build --workspace @the-vault/prompts && npm run build --workspace @the-vault/api && npm run build --workspace @the-vault/web",
    "dev:api": "npm run dev --workspace @the-vault/api",
    "dev:web": "npm run dev --workspace @the-vault/web",
    "seed:demo": "tsx apps/api/src/seed-demo.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "better-sqlite3@11.10.0": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1"
  }
}
