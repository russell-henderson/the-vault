{
  "name": "@the-vault/companion",
  "version": "1.0.4",
  "description": "Local Windows companion for The Vault Architect",
  "author": "The Vault Architect",
  "private": true,
  "type": "module",
  "main": "src/main.mjs",
  "scripts": {
    "dev": "electron .",
    "package:win": "npm run build --workspace @the-vault/api && electron-rebuild --version 37.10.3 --module-dir ../.. --force --only better-sqlite3 && electron-builder --win nsis"
  },
  "dependencies": {
    "@the-vault/api": "1.0.0"
  },
  "devDependencies": {
    "electron": "37.10.3",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.thevaultarchitect.companion",
    "productName": "Vault Companion",
    "asar": true,
    "npmRebuild": false,
    "win": { "target": ["nsis"] },
    "nsis": { "oneClick": true, "perMachine": false },
    "files": ["src/**", "package.json", "../api/dist/**", "../../packages/shared/dist/**", "../../packages/prompts/dist/**"],
    "protocols": [{ "name": "Vault Companion", "schemes": ["vault-companion"] }]
  }
}
